# ── Required ────────────────────────────────────────────────────
# Your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Absolute path to your Obsidian vault.
# For a NAS/network share, this should be the LOCAL mount point,
# e.g. /mnt/nas/MyVault  or  /Volumes/NAS/MyVault
VAULT_PATH=/path/to/your/obsidian/vault

# ── Optional ────────────────────────────────────────────────────
# Where to store the embedding index cache (default: current dir)
INDEX_CACHE_PATH=.vault_index.pkl
